# ============================================================
# Tu Bingazo — Variables de Entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@localhost:5432/NOMBRE_BD

# Clave secreta para JWT (mínimo 64 caracteres aleatorios)
SESSION_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_MUY_LARGA_Y_SEGURA

# PagosYa — Pasarela de pagos
PAGOSYA_PUBLIC_KEY=TU_CLAVE_PUBLICA
PAGOSYA_SECRET_KEY=TU_CLAVE_SECRETA
PAGOSYA_BASE_URL=https://api.pagosya.com

# Puerto del servidor (normalmente 8080)
PORT=8080
